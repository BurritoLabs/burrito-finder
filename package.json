{
  "name": "finder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "analyze": "vite build --mode analyze",
    "start": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "audit:prod": "node scripts/audit-production.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "serve:e2e": "serve -s build -l 4173",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public",
    "prettier": "prettier --write src/**/*.{js,ts,tsx,json,scss}"
  },
  "prettier": {
    "trailingComma": "none",
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@terra-money/log-finder": "^1.1.6",
    "@terra-money/log-finder-ruleset": "^3.0.3",
    "@terra-money/react-base-components": "^2.1.3",
    "@terra-money/terra.js": "^3.1.10",
    "@terra-money/terra.proto": "^2.1.0",
    "@terra.kitchen/utils": "^1.0.7",
    "@types/minimatch": "^6.0.0",
    "ace-builds": "^1.4.12",
    "assert": "^2.1.0",
    "axios": "^1.18.1",
    "bech32": "^2.0.0",
    "bignumber.js": "^9.0.1",
    "buffer": "^6.0.3",
    "classnames": "^2.2.6",
    "core-js": "^3.49.0",
    "countries-list": "^2.6.1",
    "crypto-browserify": "^3.12.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "https-browserify": "^1.0.0",
    "is-base64": "^1.1.0",
    "json5": "^2.2.3",
    "keccak256": "^1.0.6",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "ramda": "^0.27.1",
    "react": "^18.3.1",
    "react-ace": "^14.0.1",
    "react-copy-to-clipboard": "^5.1.1",
    "react-csv": "^2.2.2",
    "react-dom": "^18.3.1",
    "react-modal": "^3.16.3",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.18.1",
    "sass": "^1.101.0",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/is-base64": "^1.1.0",
    "@types/lodash": "^4.17.23",
    "@types/luxon": "^3.7.1",
    "@types/ramda": "^0.27.34",
    "@types/react": "^18.3.31",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-csv": "^1.1.2",
    "@types/react-dom": "^18.3.7",
    "@types/react-modal": "^3.10.6",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^4.3.8",
    "jsdom": "^29.1.1",
    "lint-staged": "^10.5.3",
    "prettier": "^2.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.6",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "axios": "$axios",
    "protobufjs": "7.6.5"
  }
}
